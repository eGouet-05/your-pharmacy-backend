        {
          "name": "POST Create Admin Pharmacy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const p = json.pharmacy || json;",
                  "if (p && p.id) {",
                  "  pm.collectionVariables.set('adminPharmacyId', String(p.id));",
                  "}",
                  "pm.test('Temporary pharmacist password returned', function () {",
                  "  pm.expect(json.pharmacistUser).to.be.an('object');",
                  "  pm.expect(json.pharmacistUser.temporaryPassword).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
