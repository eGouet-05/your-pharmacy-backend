              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json && json.user && json.user.pharmacyId) {",
                  "  pm.collectionVariables.set('pharmacyId', String(json.user.pharmacyId));",
                  "}",
                  "pm.test('Token is returned', function () {",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('User role is admin', function () {",
                  "  pm.expect(json.user.role).to.eql('admin');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "GET Search Medicines",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search?medicine={{searchTerm}}&userLat={{userLat}}&userLng={{userLng}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "search"
              ],
              "query": [
                {
                  "key": "medicine",
                  "value": "{{searchTerm}}"
                },
                {
                  "key": "userLat",
                  "value": "{{userLat}}"
                },
                {
                  "key": "userLng",
                  "value": "{{userLng}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
