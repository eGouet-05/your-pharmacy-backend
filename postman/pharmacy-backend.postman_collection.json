            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{newPharmacyName}}\",\n  \"email\": \"{{newPharmacyEmail}}\",\n  \"address\": \"{{newPharmacyAddress}}\",\n  \"latitude\": {{newPharmacyLat}},\n  \"longitude\": {{newPharmacyLng}}\n}"
